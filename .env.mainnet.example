STELLAR_NETWORK=mainnet
HORIZON_URL=https://horizon.stellar.org
SOROBAN_RPC_URL=https://soroban-mainnet.stellar.org
ADMIN_PUBLIC_KEY=G...
INVOICE_CONTRACT_ID=C...
TREASURY_CONTRACT_ID=C...
COMPLIANCE_CONTRACT_ID=C...
